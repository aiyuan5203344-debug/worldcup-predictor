# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration (REQUIRED - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-random-secret-key-here
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# Database
DATABASE_PATH=./database/worldcup.db

# OpenLigaDB API
OPENLIGADB_BASE_URL=https://api.openligadb.de

# CORS (comma-separated for multiple domains)
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# API-FOOTBALL (optional - free tier limited)
API_FOOTBALL_KEY=your-api-football-key
